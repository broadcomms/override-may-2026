# OVERRIDE — environment variables
# Copy this file to .env and fill in your values. Never commit .env.
# Runtime is watsonx.ai; see docs/adrs/ADR-001-watsonx-runtime.md.

# ── watsonx.ai (required) ────────────────────────────────────────────────────
WATSONX_API_KEY=replace_me
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=replace_me

# Granite model IDs served via watsonx.ai
GRANITE_INSTRUCT=ibm/granite-4-h-small
GRANITE_GUARDIAN=ibm/granite-guardian-3-8b
GRANITE_EMBEDDING=ibm/granite-embedding-278m-multilingual    # 768-dim; used at P2.5 for regulation chunk retrieval
GRANITE_CODE=ibm/granite-8b-code-instruct                    # not used in v1

# ── HuggingFace (optional, for TTM-R2 download) ──────────────────────────────
# HF_TOKEN=your_huggingface_token_here

# ── API + UI ─────────────────────────────────────────────────────────────────
OVERRIDE_API_HOST=0.0.0.0
OVERRIDE_API_PORT=8000
OVERRIDE_UI_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

# ── Data paths (relative to project root) ────────────────────────────────────
DATA_DIR=./data
SESSIONS_DIR=./data/sessions
REGS_DIR=./data/regs
SAMPLES_DIR=./data/samples

# ── Reasoning + Fan Mode parameters ──────────────────────────────────────────
REASONING_TEMPERATURE=0.3
FAN_MODE_TEMPERATURE=0.5
GUARDIAN_TEMPERATURE=0.0

# ── Validator + Guardian retry budgets ───────────────────────────────────────
VALIDATOR_MAX_RETRIES=2
GUARDIAN_MAX_RETRIES=2
GUARDIAN_PASS_THRESHOLD=0.70

# ── TTM-R2 forecasting (runs locally; optional per FR-3) ─────────────────────
TTM_R2_REPO=ibm-granite/granite-timeseries-ttm-r2
TTM_MIN_LAPS=30
TTM_FORECAST_HORIZON=5
TTM_MAX_INTERVAL_WIDTH=0.15

# ── Session limits ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=25
MAX_SESSION_LAPS=120

# ── LLM runtime — chat path only (reasoning + Fan Mode) ──────────────────────
# Default `watsonx` keeps v1.0's production behavior (the video uses this).
# `ollama` routes chat to the granite4:350m bundled in the TORCS lab container
# via the override-net service-to-service DNS (or http://localhost:11434 when
# running outside compose). The factory does a fail-loud GET /api/tags probe
# at boot — refuses to start if OVERRIDE_LLM_RUNTIME=ollama and the server
# isn't reachable. See docs/adrs/ADR-003-llm-runtime-abstraction.md.
#
# NOTE: ollama mode covers CHAT ONLY. Granite Guardian (Pass-2 safety) and
# the multilingual Granite Embedding (regulation retrieval) have no
# equivalent in granite4:350m, so they stay watsonx-only — WATSONX_API_KEY
# remains required even in ollama mode. Full ollama-only mode is v1.1.
OVERRIDE_LLM_RUNTIME=watsonx
OVERRIDE_OLLAMA_BASE_URL=http://torcs:11434
OVERRIDE_OLLAMA_MODEL=granite4:350m

# ── Phase 2: TORCS control daemon (interactive Start/Stop race) ──────────────
# Shared secret used to authenticate OVERRIDE → torcs control-plane calls
# over the internal compose network (override-net). NEVER exposed to the host:
# the daemon binds inside the torcs container on :7000 with no host port
# mapping. Generate with `python -c 'import secrets; print(secrets.token_urlsafe(32))'`
# and set in your local .env. See docs/adrs/ADR-004-torcs-control-plane.md.
#
# When this is unset, the torcs container's init script falls back to the
# legacy behavior (start.sh foreground, no daemon) — backward-compatible
# for operators who don't want the control plane.
TORCS_CONTROL_SECRET=replace_with_long_random_string

# ── TORCS kiosk mode ──────────────────────────────────────────────────────────
# Set to 1 to activate the kiosk desktop surface in the TORCS container:
#   - XFCE panels suppressed (no top bar or taskbar)
#   - Desktop file icons removed (File System, Home, Trash)
#   - Right-click context menu disabled
#   - OVERRIDE branded backdrop (logo-on-dark.png from assets/brand/)
#   - TORCS auto-launches on session start (2-second delay for compositor)
# Set to 0 (default) for the standard desktop with the manual launcher icon.
# Operator escape path: set to 0 (or unset) to restore full desktop access.
OVERRIDE_KIOSK_MODE=0

# Stop-race GUI reset (control_daemon.py only takes effect when OVERRIDE_KIOSK_MODE=1).
# After Stop race the daemon sends SIGTERM to torcs-bin so the kiosk supervisor
# (torcs-kiosk-loop.sh) relaunches TORCS cleanly in ~2-3 s.
# OVERRIDE_TORCS_GUI_RESET=0    — disable the reset entirely (default: 1 = enabled)
# OVERRIDE_TORCS_GUI_SETTLE_S   — seconds to wait after SCR stop before SIGTERM (default: 1.0)
OVERRIDE_TORCS_GUI_RESET=1
OVERRIDE_TORCS_GUI_SETTLE_S=1.0
